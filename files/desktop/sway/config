# sway config - dev-machine local desktop (Tokyo Night).
# sway is the Wayland i3-compatible compositor; a real keyboard drives it, so
# bindings use bindsym with Super ($mod = Mod4). This is the Wayland counterpart
# to the former i3/Xorg desktop: same layout/keys, Wayland-native helpers.
set $mod Mod4

font pango:JetBrainsMono Nerd Font 10

# Tokyo Night palette
set $bg   #1a1b26
set $fg   #c0caf5
set $blue #7aa2f7
set $gray #414868
set $dim  #565f89
set $red  #f7768e

# gaps and thin borders
gaps inner 8
gaps outer 3
smart_gaps on
default_border pixel 2
default_floating_border pixel 2

# class                 border  bground text  indicator child_border
client.focused          $blue   $bg     $fg   $blue     $blue
client.focused_inactive $gray   $bg     $fg   $gray     $gray
client.unfocused        $gray   $bg     $dim  $gray     $gray
client.urgent           $red    $bg     $fg   $red      $red

# terminal + launcher + kill
bindsym $mod+Return exec foot
bindsym $mod+d exec wofi --show drun
bindsym $mod+Shift+q kill

# screen lock (swaylock, Tokyo Night solid color -- see swaylock/config) plus
# swayidle: auto-lock after 15 min idle, blank the display shortly after the
# lock fires, and lock before any suspend/sleep. swayidle is event-driven
# (Wayland idle-notify), so it costs nothing while the machine is active.
bindsym $mod+Shift+x exec swaylock
exec swayidle -w \
  timeout 900 'swaylock -f' \
  timeout 910 'swaymsg "output * dpms off"' \
  resume 'swaymsg "output * dpms on"' \
  before-sleep 'swaylock -f'

# screenshots (grim + slurp, Wayland-native): select a region, then copy the grab
# to the clipboard (wl-copy) and save a timestamped PNG to ~/Pictures (XDG). The
# clipboard copy is handy to @-mention in the Copilot CLI. Print is for keyboards
# with a PrintScreen key; $mod+Shift+p is the equivalent for keyboards without one.
set $screenshot grim -g "$(slurp)" - | tee "$HOME/Pictures/$(date +%Y-%m-%d_%H-%M-%S).png" | wl-copy
bindsym Print exec $screenshot
bindsym $mod+Shift+p exec $screenshot

# focus (vim keys + arrows)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split / layout
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# reload / restart / exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'

# resize mode (plain keys, no mod)
mode "resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# HiDPI: sway scales natively per output (no xrandr/Xft.dpi script needed). Fonts
# stay one size in the configs; the compositor does the scaling. Adjust the factor
# per panel if needed (e.g. 2 for a 4K display); 1 keeps 1:1 on standard panels.
output * scale 1

# solid Tokyo Night background (no wallpaper dependency)
output * bg $bg solid_color

# bar: swaybar + i3status (lightweight; i3status runs unchanged under sway)
bar {
        status_command i3status
        separator_symbol " "
        position top
        font pango:JetBrainsMono Nerd Font 10
        colors {
                background $bg
                statusline $fg
                separator  $gray
                focused_workspace  $blue $blue $bg
                active_workspace   $gray $gray $fg
                inactive_workspace $bg   $bg   $dim
                urgent_workspace   $red  $red  $fg
        }
}
