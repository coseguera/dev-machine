# i3status - dev-machine local desktop (Tokyo Night colors, Nerd Font glyphs).
# azure-style: net (ethernet if cable, else wifi) + clock. Workspaces sit on the
# left in i3bar; this fills the right. Disk/mem/cpu intentionally omitted.
general {
        colors = true
        interval = 5
        color_good = "#9ece6a"
        color_degraded = "#e0af68"
        color_bad = "#f7768e"
}

order += "ethernet _first_"
order += "wireless _first_"
order += "tztime local"

ethernet _first_ {
        format_up = " %ip"
        format_down = ""
}

wireless _first_ {
        format_up = " %essid"
        format_down = ""
}

tztime local {
        format = " %Y-%m-%d  %H:%M"
}
